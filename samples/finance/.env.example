# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# App runtime
# CHAT: terminal chat agent
# DEMO: run predefined scenarios
APP_MODE=CHAT

# TERMINAL: approve escalated actions in terminal
# DASHBOARD: poll Bento dashboard for escalated action decisions
DEMO_MODE=TERMINAL

# Bento network: solana, ethereum, or base
BENTO_NETWORK=solana

# Wallet Ed25519
# Used to sign requests and represent the agent wallet.
AGENT_WALLET_PRIVATE_KEY=your_wallet_private_key_here
