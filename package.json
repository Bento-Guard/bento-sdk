{
  "name": "@bentoguard/sdk",
  "version": "1.2.11",
  "description": "Bento Guard SDK - AI-powered security infrastructure for autonomous agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "assets"
  ],
  "bin": {
    "bentoguard": "scripts/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate": "ts-node scratch/validate_sdk.ts",
    "demo:onchain": "ts-node bento-onchain-demo.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "changeset publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "prepare": "husky",
    "postinstall": "node scripts/banner.js",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset version && npm publish"
  },
  "keywords": [
    "bento",
    "guard",
    "ai",
    "agent",
    "security",
    "crypto",
    "x25519",
    "solana"
  ],
  "author": "Bento Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@coral-xyz/borsh": "^0.32.1",
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.4.0",
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.7.0",
    "bs58": "^4.0.1",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "prompts": "^2.4.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bs58": "^4.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "mermaid": "^11.16.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.40"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
