{
  "name": "@bentoguard/sdk",
  "version": "1.2.0",
  "description": "Bento Guard SDK - AI-powered security infrastructure for autonomous agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "samples",
    "assets"
  ],
  "bin": {
    "bentoguard": "scripts/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate": "ts-node scratch/validate_sdk.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "prepare": "npm run build",
    "postinstall": "node scripts/banner.js"
  },
  "keywords": [
    "bento",
    "guard",
    "ai",
    "agent",
    "security",
    "crypto",
    "x25519",
    "solana"
  ],
  "author": "Bento Team",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.7.0",
    "bs58": "^6.0.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "prompts": "^2.4.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}