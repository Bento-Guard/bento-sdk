# Bento Guard Backend URL
BENTO_BACKEND_URL=http://localhost:3000

# Agent Credentials
AGENT_X25519_PRIVATE_KEY=your_agent_x25519_private_key_hex
AGENT_X25519_PUBLIC_KEY=your_agent_x25519_public_key_hex

# Agent Wallet (for signing transactions)
AGENT_PRIVATE_WALLET_KEY=your_solana_private_key_base58

# Optional: System Public Key (if you want to skip fetching it)
BENTO_SYSTEM_PUBLIC_KEY=
